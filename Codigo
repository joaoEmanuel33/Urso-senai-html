<script>
let audios = [];

function goToPage(page) {
  document.getElementById('page1').classList.toggle('hidden', page !== 1);
  document.getElementById('page2').classList.toggle('hidden', page !== 2);
  document.getElementById('tab1').classList.toggle('active', page === 1);
  document.getElementById('tab2').classList.toggle('active', page === 2);
  if (page === 2) renderAudios(audios);
}

document.getElementById('helpBtn').addEventListener('click', function(e) {
  e.stopPropagation();
  document.getElementById('helpPopup').classList.remove('hidden');
});

function closeHelp(e) {
  if (!e || e.target === document.getElementById('helpPopup')) {
    document.getElementById('helpPopup').classList.add('hidden');
  }
}

document.getElementById('upload').addEventListener('change', async function() {
  const files = Array.from(this.files);
  if (!files.length) return;
  this.value = '';

  const statusEl = document.getElementById('upload-status');
  const overlay  = document.getElementById('loadingOverlay');
  const msgEl    = document.getElementById('loadingMsg');

  for (let i = 0; i < files.length; i++) {
    const file = files[i];

    overlay.classList.remove('hidden');
    msgEl.textContent = `Enviando ${i+1}/${files.length}: ${file.name}`;

    let uploadedOk = false;
    try {
      const fd = new FormData();
      fd.append('audio', file, file.name);
      const resp = await fetch('/upload', { method: 'POST', body: fd });
      if (resp.ok) {
        uploadedOk = true;
        audios.push({ name: file.name, url: '/audio?name=' + encodeURIComponent(file.name) });
      }
    } catch (_) {}

    if (!uploadedOk) {
      audios.push({ name: file.name, url: URL.createObjectURL(file) });
    }
  }

  overlay.classList.add('hidden');
  statusEl.className = 'success';
  statusEl.textContent = `${files.length} áudio(s) adicionado(s)!`;
  setTimeout(() => { statusEl.textContent = ''; statusEl.className = ''; }, 3000);

  goToPage(2);
});

function fmtTime(s) {
  if (!isFinite(s)) return '0:00';
  const m = Math.floor(s / 60);
  const sec = Math.floor(s % 60).toString().padStart(2, '0');
  return `${m}:${sec}`;
}

function renderAudios(lista) {
  const container = document.getElementById('audioList');
  container.innerHTML = '';

  if (!lista.length) {
    container.innerHTML = '<p class="empty-msg">Nenhum áudio encontrado.</p>';
    return;
  }

  lista.forEach((audio) => {
    const realIdx = audios.indexOf(audio);
    const card = document.createElement('div');
    card.className = 'audio-card';
    card.innerHTML = `
      <div class="audio-header">
        <span class="audio-name" title="${audio.name}">${audio.name}</span>
        <button class="del-btn" aria-label="Remover">✕</button>
      </div>
      <audio id="audio-${realIdx}" src="${audio.url}" preload="metadata"></audio>
      <div class="progress-wrap" id="pw-${realIdx}">
        <div class="progress-bar" id="bar-${realIdx}"></div>
      </div>
      <div class="time-label" id="time-${realIdx}">0:00 / 0:00</div>
      <div class="controls">
        <button class="ctrl-btn" id="rew-${realIdx}" aria-label="Recuar 5s">⏮</button>
        <button class="ctrl-btn play" id="play-${realIdx}" aria-label="Play">▶</button>
        <button class="ctrl-btn" id="fwd-${realIdx}" aria-label="Avançar 5s">⏭</button>
      </div>
    `;
    container.appendChild(card);

    const audioEl = document.getElementById(`audio-${realIdx}`);
    const bar     = document.getElementById(`bar-${realIdx}`);
    const timeEl  = document.getElementById(`time-${realIdx}`);
    const playBtn = document.getElementById(`play-${realIdx}`);
    const pw      = document.getElementById(`pw-${realIdx}`);

    card.querySelector('.del-btn').addEventListener('click', () => deleteAudio(realIdx));
    playBtn.addEventListener('click', () => togglePlay(realIdx));

    document.getElementById(`rew-${realIdx}`).addEventListener('click', () => {
      audioEl.currentTime = Math.max(0, audioEl.currentTime - 5);
    });
    document.getElementById(`fwd-${realIdx}`).addEventListener('click', () => {
      audioEl.currentTime = Math.min(audioEl.duration || 0, audioEl.currentTime + 5);
    });

    audioEl.addEventListener('timeupdate', () => {
      if (!audioEl.duration) return;
      bar.style.width = (audioEl.currentTime / audioEl.duration * 100) + '%';
      timeEl.textContent = `${fmtTime(audioEl.currentTime)} / ${fmtTime(audioEl.duration)}`;
    });

    pw.addEventListener('click', (e) => {
      if (!audioEl.duration) return;
      const rect = pw.getBoundingClientRect();
      audioEl.currentTime = ((e.clientX - rect.left) / rect.width) * audioEl.duration;
    });

    audioEl.addEventListener('ended', () => { playBtn.textContent = '▶'; });
    audioEl.addEventListener('pause', () => { playBtn.textContent = '▶'; });
    audioEl.addEventListener('play',  () => { playBtn.textContent = '⏸'; });
  });

  const delAll = document.createElement('button');
  delAll.className = 'delete-all-btn';
  delAll.textContent = '🗑 Apagar tudo';
  delAll.addEventListener('click', deleteAllAudios);
  container.appendChild(delAll);
}

function togglePlay(i) {
  const a = document.getElementById(`audio-${i}`);
  if (!a) return;
  document.querySelectorAll('audio').forEach(el => { if (el !== a) el.pause(); });
  a.paused ? a.play() : a.pause();
}

function deleteAudio(i) {
  const a = document.getElementById(`audio-${i}`);
  if (a) a.pause();
  audios.splice(i, 1);
  renderAudios(audios);
}

function deleteAllAudios() {
  document.querySelectorAll('audio').forEach(a => a.pause());
  audios = [];
  renderAudios(audios);
}

function filterAudios() {
  const s = document.getElementById('search').value.toLowerCase();
  renderAudios(audios.filter(a => a.name.toLowerCase().includes(s)));
}
</script>
