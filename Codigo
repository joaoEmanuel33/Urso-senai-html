// ================= UPLOAD HANDLER =================
File   uploadFile;
String uploadFileName;

void handleUpload() {
  HTTPUpload& upload = server.upload();

  if (upload.status == UPLOAD_FILE_START) {
    uploadFileName = "/" + upload.filename;
    if (SPIFFS.exists(uploadFileName)) SPIFFS.remove(uploadFileName);
    uploadFile = SPIFFS.open(uploadFileName, FILE_WRITE);

  } else if (upload.status == UPLOAD_FILE_WRITE) {
    if (uploadFile) uploadFile.write(upload.buf, upload.currentSize);

  } else if (upload.status == UPLOAD_FILE_END) {
    if (uploadFile) uploadFile.close();
  }
}

void handleUploadPost() {
  server.send(200, "application/json",
    "{\"ok\":true,\"file\":\"" + uploadFileName + "\"}");
}

// ================= SERVIR ÁUDIO DO SPIFFS =================
void handleAudioServe() {
  if (!server.hasArg("name")) {
    server.send(400, "text/plain", "Parametro 'name' obrigatorio");
    return;
  }
  String path = "/" + server.arg("name");
  if (!SPIFFS.exists(path)) {
    server.send(404, "text/plain", "Arquivo nao encontrado");
    return;
  }
  File f = SPIFFS.open(path, FILE_READ);
  server.streamFile(f, "audio/mpeg");
  f.close();
}

// ================= OUTRAS ROTAS =================
void handleRoot() {
  server.send_P(200, "text/html", index_html);
}

void handleStatus() {
  String json = "{";
  json += "\"status\":\"online\",";
  json += "\"ssid\":\""   + String(ssid) + "\",";
  json += "\"ip\":\"192.168.4.1\",";
  json += "\"clients\":" + String(WiFi.softAPgetStationNum());
  json += "}";
  server.send(200, "application/json", json);
}

void handlePing() {
  server.send(200, "text/plain", "pong");
}

void handleNotFound() {
  server.send(404, "text/plain",
    "Rota nao encontrada\n\nRotas:\nGET /\nGET /status\nGET /ping\nPOST /upload\nGET /audio?name=<arquivo>");
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);
  delay(1000);

  if (!SPIFFS.begin(true)) {
    Serial.println("ERRO: Falha ao montar SPIFFS");
  } else {
    Serial.println("SPIFFS montado com sucesso");
  }

  WiFi.softAPConfig(local_ip, gateway, subnet);
  WiFi.softAP(ssid, password);

  Serial.println("==================================");
  Serial.println("Access Point criado!");
  Serial.println("SSID: "  + String(ssid));
  Serial.println("Senha: " + String(password));
  Serial.println("IP: "    + WiFi.softAPIP().toString());
  Serial.println("==================================");

  server.on("/",       HTTP_GET,  handleRoot);
  server.on("/status", HTTP_GET,  handleStatus);
  server.on("/ping",   HTTP_GET,  handlePing);
  server.on("/audio",  HTTP_GET,  handleAudioServe);
  server.on("/upload", HTTP_POST, handleUploadPost, handleUpload);
  server.onNotFound(handleNotFound);
  server.begin();

  Serial.println("Servidor HTTP iniciado (porta 80)");
  Serial.println("Acesse http://192.168.4.1");
}

// ================= LOOP =================
void loop() {
  server.handleClient();
}
